{
  "name": "ngk-dashboard",
  "version": "1.7.2",
  "description": "A ready-to-use React component library: themed shadcn/ui primitives with dark mode baked in. Install, import one stylesheet, and go.",
  "license": "MIT",
  "author": "khoinguyen12200",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khoinguyen12200/ngk-dashboard.git"
  },
  "homepage": "https://github.com/khoinguyen12200/ngk-dashboard#readme",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "BEST_PRACTICES.md",
    "COMPONENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./ui/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.js"
    },
    "./layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/components/layout/index.js"
    },
    "./page": {
      "types": "./dist/components/page/index.d.ts",
      "import": "./dist/components/page/index.js"
    },
    "./theme": {
      "types": "./dist/components/theme/index.d.ts",
      "import": "./dist/components/theme/index.js"
    },
    "./data-table": {
      "types": "./dist/components/data-table/index.d.ts",
      "import": "./dist/components/data-table/index.js"
    },
    "./date-picker": {
      "types": "./dist/components/date-picker.d.ts",
      "import": "./dist/components/date-picker.js"
    },
    "./confirm-dialog": {
      "types": "./dist/components/confirm-dialog.d.ts",
      "import": "./dist/components/confirm-dialog.js"
    },
    "./password-input": {
      "types": "./dist/components/password-input.d.ts",
      "import": "./dist/components/password-input.js"
    },
    "./long-text": {
      "types": "./dist/components/long-text.d.ts",
      "import": "./dist/components/long-text.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "build": "npm run build:js && npm run build:css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "tsc -p type-tests/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run typecheck && npm run test:types && npm run test",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.6.2",
    "react-day-picker": "9.14.0",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.0",
    "vitest": "^3.2.7"
  }
}
